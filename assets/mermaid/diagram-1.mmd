flowchart LR
  classDef intake fill:#101827,stroke:#6ee7ff,stroke-width:2px,color:#eef6ff
  classDef artifact fill:#141b2d,stroke:#a78bfa,stroke-width:2px,color:#f4f0ff
  classDef gate fill:#2a1a12,stroke:#f59e0b,stroke-width:2px,color:#fff7ed
  classDef memory fill:#10251c,stroke:#34d399,stroke-width:2px,color:#ecfdf5
  classDef spine fill:#172033,stroke:#38bdf8,stroke-width:3px,color:#f8fbff

  subgraph I[Intent and problem frame]
    direction TB
    A([Human intent]):::intake
    A1[Non-goals and failure modes]:::intake
    A2[Constraints and evidence sources]:::intake
    A --> A1 --> A2
  end

  subgraph S[Spec artifact spine]
    direction TB
    B[Requirements contract]:::artifact
    C[Context and constraints]:::artifact
    D[Design artifact]:::artifact
    E[Traceable task graph]:::artifact
    B --> C --> D --> E
  end

  subgraph X[Execution and proof loop]
    direction TB
    F[Implementation handoff packet]:::spine
    G{Verification gate}:::gate
    H[(Archive and change memory)]:::memory
    F --> G --> H
  end

  GOV[[Constitution and governance]]:::gate
  TR[[Traceability map]]:::spine
  HUMAN[[Human checkpoint cadence]]:::gate

  A2 ==> B
  E ==> F
  H == informs next change ==> B
  GOV -. constrains .-> B
  GOV -. constrains .-> D
  GOV -. constrains .-> G
  TR -. links .-> B
  TR -. links .-> D
  TR -. links .-> E
  TR -. proves .-> G
  HUMAN -. approves .-> A
  HUMAN -. approves .-> D
  HUMAN -. accepts evidence .-> G